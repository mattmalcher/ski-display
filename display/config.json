{
  "display": {
    "scroll_speed": 36,
    "frame_time": 0.016,
    "contrast": 3,
    "scheduler_refresh_interval": 5.0,
    "off_times": [
      {"start": "00:00", "end": "07:00"}
    ]
  },
  "modules": [
    {
      "name": "clock",
      "enabled": true,
      "duration": 5.0
    },
{
      "name": "textfile",
      "enabled": true,
      "file": "messages.txt",
      "reload_interval": 2.0
    },
    {
      "name": "weather",
      "enabled": true,
      "location": "Aviemore",
      "fetch_interval": 600
    },
    {
      "name": "stock",
      "enabled": true,
      "symbols": ["AAPL", "TSLA"],
      "fetch_interval": 300
    },
    {
      "name": "print_status",
      "enabled": false,
      "octoprint_url": "http://octopi.local",
      "api_key": "",
      "fetch_interval": 30
    },
    {
      "name": "home_assistant",
      "enabled": false,
      "ha_url": "http://homeassistant.local:8123",
      "token": "your-long-lived-access-token",
      "entity_ids": ["sensor.living_room_temperature"],
      "fetch_interval": 60,
      "ttl": 120
    },
    {
      "name": "ics",
      "enabled": false,
      "ical_url": "https://...",
      "days_ahead": 7,
      "fetch_interval": 900
    },
    {
      "name": "claude_usage",
      "enabled": false,
      "session_key": "sk-ant-sid01-...",
      "org_id": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
      "fetch_interval": 120
    },
    {
      "name": "notable_dates",
      "enabled": false,
      "dates": [
        {
          "date": "2026-12-25",
          "message": "Merry Christmas!",
          "repeat": "annual",
          "reminder_days": [7, 3, 1]
        },
        {
          "date": "2026-06-15",
          "message": "Summer hols begin",
          "repeat": "none",
          "reminder_days": [14, 7]
        },
        {
          "date": "2026-03-19",
          "message": "Recycling bins",
          "repeat": "weekly",
          "interval_weeks": 2,
          "reminder_days": [1]
        }
      ]
    }
  ]
}
